{
  "manifest_version": 3,
  "name": "IBISWorld Outreach",
  "version": "3.28.0",
  "description": "Outlook DOM overlay — staleness badges on campaign folders and email rows.",
  "content_scripts": [
    {
      "matches": [
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*",
        "https://outlook.microsoft.com/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://dabbs4dan.github.io/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "IBISWorld Outreach",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://dabbs4dan.github.io/*",
    "https://outlook.cloud.microsoft/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.live.com/*",
    "https://outlook.microsoft.com/*",
    "https://*.sharepoint.com/*",
    "https://www.google.com/*"
  ]
}
