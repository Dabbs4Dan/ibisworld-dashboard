{
  "manifest_version": 3,
  "name": "IBISWorld Outreach",
  "version": "2.0.0",
  "description": "Priority-based contact engine for IBISWorld sales — powered by your dashboard and real Outlook email history.",
  "content_scripts": [
    {
      "matches": [
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*",
        "https://outlook.microsoft.com/*"
      ],
      "js": ["config.js", "content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://dabbs4dan.github.io/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://dabbs4dan.github.io/*",
    "https://outlook.cloud.microsoft/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.live.com/*",
    "https://graph.microsoft.com/*"
  ],
  "action": {
    "default_title": "IBISWorld Outreach"
  }
}
